<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>To Do List App - Edit Task</title>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4 class="mb-0"> <i class="fa-regular fa-pen-to-square" style="color: rgb(23, 152, 221);"></i> Edit Task</h4>
                    </div>
                    <div class="card-body">
                        <form action="/update/<%= task.id %>" method="post">
                            <div class="mb-3">
                                <label for="taskName" class="form-label">Task Name *</label>
                                <input type="text" class="form-control" id="taskName" name="taskName" value="<%= task.name %>" required>
                            </div>
                            <div class="mb-3">
                                <label for="deadline" class="form-label">Deadline</label>
                                <input type="date" class="form-control" id="deadline" name="deadline" value="<%= task.deadline %>">
                                <small class="text-muted">Optional. Leave blank if no deadline.</small>
                            </div>
                            <div class="mb-3">
                                <label for="priority" class="form-label">Priority</label>
                                <select class="form-select" id="priority" name="priority">
                                    <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>🔴 High</option>
                                    <option value="medium" <%= task.priority === 'medium' ? 'selected' : '' %>>🟡 Medium</option>
                                    <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>🟢 Low</option>
                                </select>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn-simple btn-edit"><i class="fa-solid fa-arrow-rotate-left" style="color: rgb(23, 152, 221);"></i>Update Task</button>
                                <a href="/" class="btn-simple btn-undo"><i class="fa-regular fa-circle-xmark" style="color: rgb(23, 152, 221);"></i> Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>