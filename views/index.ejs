<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>To Do List App - Home</title>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <!-- title -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="page-title">MY TASKS LIST</h1>
            <a href="/additem" class="btn-circle">+</a>
        </div>

        <!-- card -->
        <div class="stats-card">
            <div class="row text-center">
                <div class="col-3">
                    <h6>TOTAL</h6>
                    <h4><%= tasks.length %></h4>
                </div>
                <div class="col-3">
                    <h6>IN PROGRESS</h6>
                    <h4><%= tasks.filter(t => !t.completed).length %></h4>
                </div>
                <div class="col-3">
                    <h6>COMPLETED</h6>
                    <h4><%= tasks.filter(t => t.completed).length %></h4>
                </div>
                <div class="col-3">
                    <h6>TODAY</h6>
                    <h4><%= tasks.filter(t => t.deadline === todayDate).length %></h4>
                </div>
            </div>
        </div>

        <% if (tasks.length === 0) { %>
            <div class="card">
                <div class="card-body empty-state">
                    <div class="empty-state-icon">✨</div>
                    <p class="empty-state-text">No tasks yet. Click the + button to get started!</p>
                </div>
            </div>
        <% } else { %>
            <!-- Unfinished task -->
            <div class="card mb-4">
                <div class="card-header bg-warning">
                    <span>⏳ IN PROGRESS</span>
                    <span class="card-header-badge"><%= tasks.filter(t => !t.completed).length %></span>
                </div>
                <ul class="list-group list-group-flush">
                    <% const incompleteTasks = tasks.filter(t => !t.completed); %>
                    <% if (incompleteTasks.length === 0) { %>
                        <li class="list-group-item text-muted text-center py-4">✨ No pending tasks. Great job! ✨</li>
                    <% } else { %>
                        <% incompleteTasks.forEach(task => { %>
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start flex-wrap">
                                    <div class="flex-grow-1">
                                        <div class="task-name"><%= task.name %></div>
                                        <div class="mt-1">
                                            <span class="text-muted" style="font-size: 0.75rem;"><i class="fa-regular fa-calendar-days" style="color: rgb(23, 152, 221);"></i> <%= task.deadline || 'No deadline' %></span>
                                            <span class="priority-badge ms-2"><%= task.priority %></span>
                                        </div>
                                    </div>
                                    <div class="action-buttons mt-2 mt-sm-0">
                                        <a href="/view/<%= task.id %>" class="btn-simple btn-view" title="View task details"><i class="fa-solid fa-layer-group" style="color: rgb(23, 152, 221);"></i> VIEW</a>
                                        <form action="/toggle/<%= task.id %>" method="post" style="display:inline">
                                            <button class="btn-simple btn-complete" title="Mark as complete"><i class="fa-solid fa-check" style="color: rgb(23, 152, 221);"></i></button>
                                        </form>
                                        <a href="/edit/<%= task.id %>" class="btn-simple btn-edit" title="Edit this task"><i class="fa-regular fa-pen-to-square" style="color: rgb(23, 152, 221);"></i> EDIT</a>
                                        <form action="/delete/<%= task.id %>" method="post" style="display:inline">
                                            <button class="btn-simple btn-delete" title="Delete this task" onclick="return confirm('Are you sure?')"><i class="fa-solid fa-trash" style="color: rgb(116, 192, 252);"></i> DELETE</button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        <% }); %>
                    <% } %>
                </ul>
            </div>

            <!-- Task completed  -->
            <div class="card">
                <div class="card-header bg-success text-black">
                    <span><i class="fa-solid fa-check" style="color: rgb(23, 152, 221);"></i> COMPLETED</span>
                    <span class="card-header-badge"><%= tasks.filter(t => t.completed).length %></span>
                </div>
                <ul class="list-group list-group-flush">
                    <% const completedTasks = tasks.filter(t => t.completed); %>
                    <% if (completedTasks.length === 0) { %>
                        <li class="list-group-item text-muted text-center py-4">⭐ No completed tasks yet ⭐</li>
                    <% } else { %>
                        <% completedTasks.forEach(task => { %>
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start flex-wrap">
                                    <div class="flex-grow-1">
                                        <div class="completed-task-name"><%= task.name %></div>
                                        <div class="mt-1">
                                            <span class="text-muted" style="font-size: 0.75rem;"><i class="fa-regular fa-calendar-days" style="color: rgb(23, 152, 221);"></i> <%= task.deadline || 'No deadline' %></span>
                                            <span class="priority-badge ms-2"><%= task.priority %></span>
                                        </div>
                                    </div>
                                    <div class="action-buttons mt-2 mt-sm-0">
                                        <a href="/view/<%= task.id %>" class="btn-simple btn-view" title="View task details"><i class="fa-solid fa-layer-group" style="color: rgb(23, 152, 221);"></i> VIEW</a>
                                        <form action="/toggle/<%= task.id %>" method="post" style="display:inline">
                                            <button class="btn-simple btn-undo" title="Undo complete"><i class="fa-solid fa-undo" style="color: rgb(23, 152, 221);"></i></button>
                                        </form>
                                        <a href="/edit/<%= task.id %>" class="btn-simple btn-edit" title="Edit this task"><i class="fa-regular fa-pen-to-square" style="color: rgb(23, 152, 221);"></i> EDIT</a>
                                        <form action="/delete/<%= task.id %>" method="post" style="display:inline">
                                            <button class="btn-simple btn-delete" title="Delete this task" onclick="return confirm('Are you sure?')"><i class="fa-solid fa-trash" style="color: rgb(116, 192, 252);"></i> DELETE</button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        <% }); %>
                    <% } %>
                </ul>
            </div>
        <% } %>
    </div>

    <%- include('partials/footer') %>
</body>
</html>