<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>To Do List App - View Task</title>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="fa-solid fa-layer-group" style="color: rgb(23, 152, 221);"></i> Task Details</h4>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless">
                            <tr>
                                <th style="width: 35%">Task ID</th>
                                <td><%= task.id %></td>
                            </tr>
                            <tr>
                                <th>Task Name</th>
                                <td><%= task.name %></td>
                            </tr>
                            <tr>
                                <th>Deadline</th>
                                <td><%= task.deadline || 'No deadline set' %></td>
                            </tr>
                            <tr>
                                <th>Priority</th>
                                <td><span class="priority-badge"><%= task.priority %></span></td>
                            </tr>
                            <tr>
                                <th>Status</th>
                                <td>
                                    <% if (task.completed) { %>
                                        <span class="priority-badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">✅ Completed</span>
                                    <% } else { %>
                                        <span class="priority-badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">⏳ In Progress</span>
                                    <% } %>
                                </td>
                            </tr>
                        </table>

                      <div class="action-buttons">
                            <!-- View-->
                            <a href="/" class="btn-simple btn-view" title="View details"><i class="fa-regular fa-circle-xmark" style="color: rgb(23, 152, 221);"></i> Cancel</a>
                            
                            <!-- Complete-->
                            <form action="/toggle/<%= task.id %>" method="post" style="display:inline">
                                <button class="btn-simple btn-complete" title="Mark as complete"><i class="fa-solid fa-check" style="color: rgb(23, 152, 221);"></i> COMPLETE</button>
                            </form>
                            
                            <!-- Edit -->
                            <a href="/edit/<%= task.id %>" class="btn-simple btn-edit" title="Edit task"><i class="fa-regular fa-pen-to-square" style="color: rgb(23, 152, 221);"></i> EDIT</a>
                            
                            <!-- Delete -->
                            <form action="/delete/<%= task.id %>" method="post" style="display:inline">
                                <button class="btn-simple btn-delete" title="Delete task" onclick="return confirm('Are you sure?')"><i class="fa-solid fa-trash" style="color: rgb(116, 192, 252);"></i> DELETE</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <%- include('partials/footer') %>
</body>
</html>